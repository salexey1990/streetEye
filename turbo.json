{
  "$schema": "https://turborepo.dev/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": [
    "NODE_ENV",
    "CHALLENGE_SERVICE_DB_HOST",
    "CHALLENGE_SERVICE_DB_PORT",
    "CHALLENGE_SERVICE_DB_USERNAME",
    "CHALLENGE_SERVICE_DB_PASSWORD",
    "CHALLENGE_SERVICE_DB_DATABASE",
    "CHALLENGE_SERVICE_PORT",
    "CONTENT_SERVICE_DB_HOST",
    "CONTENT_SERVICE_DB_PORT",
    "CONTENT_SERVICE_DB_USERNAME",
    "CONTENT_SERVICE_DB_PASSWORD",
    "CONTENT_SERVICE_DB_DATABASE",
    "CONTENT_SERVICE_PORT",
    "API_DB_HOST",
    "API_DB_PORT",
    "API_DB_USERNAME",
    "API_DB_PASSWORD",
    "API_DB_DATABASE",
    "API_PORT",
    "REDIS_HOST",
    "REDIS_PORT",
    "REDIS_PASSWORD",
    "REDIS_TTL",
    "RABBITMQ_URI",
    "RABBITMQ_EXCHANGE",
    "RABBITMQ_QUEUE_PREFIX"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {},
    "test": {},
    "test:e2e": {}
  }
}
