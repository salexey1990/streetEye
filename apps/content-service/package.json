{
  "name": "content-service",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:prepare": "dotenv -e ../../.env.test -- echo 'Test environment ready'",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "db:up": "cd ../../ && docker-compose up -d content-service-db",
    "db:down": "cd ../../ && docker-compose stop content-service-db",
    "db:test:up": "cd ../../ && docker-compose up -d content-service-db-test",
    "db:test:down": "cd ../../ && docker-compose stop content-service-db-test",
    "db:restart": "cd ../../ && docker-compose restart content-service-db",
    "db:logs": "cd ../../ && docker-compose logs -f content-service-db",
    "db:all:up": "cd ../../ && docker-compose up -d",
    "db:all:down": "cd ../../ && docker-compose down"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.11",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.11",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/typeorm": "^11.0.0",
    "@repo/api": "workspace:*",
    "escape-html": "^1.0.3",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.11",
    "@repo/eslint-config": "workspace:*",
    "@repo/jest-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.5.4"
  }
}
